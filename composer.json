{
    "name": "nette/sandbox",
    "description": "The sandbox is a pre-packaged Nette Framework project, basic configured structure for your application.",
    "homepage": "https://nette.org",
    "type": "project",
    "license": ["BSD-3-Clause", "GPL-2.0", "GPL-3.0"],
    "authors": [
        {
            "name": "David Grudl",
            "homepage": "https://davidgrudl.com"
        },
        {
            "name": "Nette Community",
            "homepage": "https://nette.org/contributors"
        }
    ],
    "require": {
        "php": ">= 8.3",
        "ext-pdo": "*",
        "ext-intl": "*",
        "nette/application": "^3.3",
        "nette/assets": "^1.0",
        "nette/bootstrap": "^3.3",
        "nette/caching": "^3.4",
        "nette/di": "^3.2",
        "nette/finder": "^3.0",
        "nette/forms": "^3.2.2",
        "nette/http": "^3.4",
        "nette/mail": "^4.1",
        "nette/robot-loader": "^4.1",
        "nette/security": "^3.2",
        "nette/utils": "^4.1",
        "latte/latte": "^3.1",
        "tracy/tracy": "^2.5.3",
        "dibi/dibi": "^5.1",
        "ifsnop/mysqldump-php": "2.*",
        "kdyby/forms-replicator": "@dev",
        "contributte/console": "^0.11.0",
        "contributte/console-extra": "^0.8.0",
        "contributte/redis": "^0.6.0",
        "contributte/forms-bootstrap": "^0.9.x-dev",
        "contributte/guzzlette": "^3.4",
        "contributte/mail": "^0.9.0",
        "contributte/mailing": "^0.7.1",
        "contributte/translation": "^2.0",
        "nettrine/dbal": "^0.10.3",
        "nettrine/fixtures": "^0.9.0",
        "nettrine/migrations": "^0.10.1",
        "nettrine/extensions-beberlei": "^0.3.0",
        "nettrine/orm": "^0.10.1",
        "uestla/recaptcha-control": "^9.0",
        "nextras/secured-links": "^1.10",
        "radekdostal/nette-datetimepicker": "^3.2",
        "ublaboo/datagrid": "^7.2",
        "symfony/cache": "^7.2",
        "ramsey/uuid": "^4.9",
        "ramsey/uuid-doctrine": "^2.1",
        "symfony/var-exporter": "^7.2",
        "jgxvx/cilician": "^6.1",
        "contributte/menu-control": "^3.2",
        "ext-mbstring": "*",
        "donatj/phpuseragentparser": "^1.12"
    },
    "require-dev": {
        "nette/tester": "^v2.3.5",
        "dg/composer-frontline": "v0.2",
        "ninjify/coding-standard": "^0.12.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-nette": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "roave/security-advisories": "dev-latest",
        "symfony/thanks": "^1",
        "rector/rector": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "dg/composer-frontline": true,
            "symfony/thanks": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
